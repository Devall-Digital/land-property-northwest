# Land & Property Northwest - Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# These are also needed as Cursor Secrets for cloud agents.

# FTP Deployment
FTP_HOST=ftp.gb.stackcp.com
FTP_USER=land-property-northwest.co.uk
FTP_PASS=

# WordPress Admin
WP_URL=https://land-property-northwest.co.uk
WP_ADMIN_USER=admin
WP_ADMIN_PASS=

# Stripe (use test keys during development)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Mautic
MAUTIC_URL=https://mail.land-property-northwest.co.uk
MAUTIC_USER=
MAUTIC_PASS=

# EPC Open Data API (register free at https://epc.opendatacommunities.org/login)
EPC_API_KEY=

# Google (optional, for Search Console verification)
GOOGLE_SITE_VERIFICATION=
